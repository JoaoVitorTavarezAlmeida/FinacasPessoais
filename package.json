{
  "name": "fatec-financas",
  "version": "0.1.0",
  "private": true,
  "description": "Dashboard de financas pessoais em Next.js com Prisma e PostgreSQL.",
  "repository": {
    "type": "git",
    "url": "https://github.com/JoaoVitorTavarezAlmeida/FinacasPessoais.git"
  },
  "scripts": {
    "db:up": "node scripts/compose.mjs up -d",
    "db:down": "node scripts/compose.mjs down",
    "db:reset": "node scripts/compose.mjs down -v",
    "env:ensure": "node scripts/ensure-env.mjs",
    "db:wait": "node scripts/wait-for-db.mjs",
    "dev": "next dev",
    "dev:full": "npm run env:ensure && npm run db:up && npm run db:wait && npm run prisma:generate && npm run prisma:migrate:deploy && npm run prisma:seed && npm run dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "node prisma/seed.mjs",
    "setup": "npm run env:ensure && npm run db:wait && npm run prisma:generate && npm run prisma:migrate:deploy && npm run prisma:seed",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.3",
    "next": "16.1.6",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.5.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
